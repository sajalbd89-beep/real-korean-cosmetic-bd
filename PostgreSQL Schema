-- Extensions
CREATE EXTENSION IF NOT EXISTS "uuid-ossp";
CREATE EXTENSION IF NOT EXISTS pg_trgm; -- for fast text search

-- ─── BRANDS ───────────────────────────────────────────────
CREATE TABLE brands (
  id          UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
  name        TEXT NOT NULL UNIQUE,           -- "COSRX", "Laneige"
  origin      TEXT DEFAULT 'Korea',
  logo_url    TEXT,
  created_at  TIMESTAMPTZ DEFAULT now()
);

-- ─── TAXONOMY TABLES ──────────────────────────────────────
CREATE TABLE skin_types (
  id    SMALLSERIAL PRIMARY KEY,
  label TEXT NOT NULL UNIQUE  -- Oily, Dry, Combination, Sensitive, Normal
);

CREATE TABLE concerns (
  id    SMALLSERIAL PRIMARY KEY,
  label TEXT NOT NULL UNIQUE  -- Acne, Anti-aging, Brightening, Pores, Hydration
);

CREATE TABLE ingredients (
  id          UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
  inci_name   TEXT NOT NULL UNIQUE,   -- INCI standard name
  common_name TEXT,
  is_allergen BOOLEAN DEFAULT false
);

-- ─── PRODUCTS ─────────────────────────────────────────────
CREATE TABLE products (
  id            UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
  sku           TEXT NOT NULL UNIQUE,
  name          TEXT NOT NULL,
  slug          TEXT NOT NULL UNIQUE,         -- SEO-friendly URL
  brand_id      UUID REFERENCES brands(id),
  description   TEXT,
  price_bdt     NUMERIC(10,2) NOT NULL,
  compare_price NUMERIC(10,2),               -- for "sale" badges
  weight_g      SMALLINT,
  volume_ml     SMALLINT,
  images        TEXT[],                       -- ordered array of Supabase Storage URLs
  tags          TEXT[],                       -- free-form: "bestseller", "new"
  meta_title    TEXT,                        -- SEO overrides
  meta_desc     TEXT,
  is_published  BOOLEAN DEFAULT false,
  created_at    TIMESTAMPTZ DEFAULT now(),
  updated_at    TIMESTAMPTZ DEFAULT now(),
  search_vec    TSVECTOR                      -- full-text search
);

-- GIN indexes for array & FTS operations
CREATE INDEX idx_products_tags       ON products USING GIN(tags);
CREATE INDEX idx_products_search     ON products USING GIN(search_vec);
CREATE INDEX idx_products_brand      ON products(brand_id);
CREATE INDEX idx_products_published  ON products(is_published);

-- Auto-populate search vector
CREATE OR REPLACE FUNCTION products_search_trigger() RETURNS trigger AS $$
BEGIN
  NEW.search_vec := to_tsvector('english',
    coalesce(NEW.name,'') || ' ' ||
    coalesce(NEW.description,'') || ' ' ||
    coalesce(array_to_string(NEW.tags,' '),''));
  RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER products_search BEFORE INSERT OR UPDATE ON products
  FOR EACH ROW EXECUTE FUNCTION products_search_trigger();

-- ─── JUNCTION TABLES (many-to-many) ───────────────────────
CREATE TABLE product_skin_types (
  product_id   UUID REFERENCES products(id) ON DELETE CASCADE,
  skin_type_id SMALLINT REFERENCES skin_types(id),
  PRIMARY KEY (product_id, skin_type_id)
);

CREATE TABLE product_concerns (
  product_id  UUID REFERENCES products(id) ON DELETE CASCADE,
  concern_id  SMALLINT REFERENCES concerns(id),
  PRIMARY KEY (product_id, concern_id)
);

CREATE TABLE product_ingredients (
  product_id    UUID REFERENCES products(id) ON DELETE CASCADE,
  ingredient_id UUID REFERENCES ingredients(id),
  position      SMALLINT,   -- ingredient list ordering
  PRIMARY KEY (product_id, ingredient_id)
);

-- ─── INVENTORY ────────────────────────────────────────────
CREATE TABLE inventory (
  product_id   UUID PRIMARY KEY REFERENCES products(id),
  qty_on_hand  INT NOT NULL DEFAULT 0,
  qty_reserved INT NOT NULL DEFAULT 0,
  low_stock_at INT DEFAULT 5,
  updated_at   TIMESTAMPTZ DEFAULT now()
);

-- ─── ORDERS ───────────────────────────────────────────────
CREATE TYPE payment_method AS ENUM ('bkash','nagad','cod');
CREATE TYPE order_status   AS ENUM ('pending','confirmed','processing','shipped','delivered','cancelled','refunded');

CREATE TABLE customers (
  id         UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
  name       TEXT NOT NULL,
  phone      TEXT NOT NULL UNIQUE,
  email      TEXT,
  address    JSONB,           -- {line1, city, district, postcode}
  created_at TIMESTAMPTZ DEFAULT now()
);

CREATE TABLE orders (
  id               UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
  customer_id      UUID REFERENCES customers(id),
  status           order_status DEFAULT 'pending',
  payment_method   payment_method NOT NULL,
  payment_tx_id    TEXT,        -- bKash/Nagad transaction ID
  payment_verified BOOLEAN DEFAULT false,
  subtotal_bdt     NUMERIC(10,2),
  shipping_bdt     NUMERIC(10,2) DEFAULT 60,
  total_bdt        NUMERIC(10,2),
  notes            TEXT,
  created_at       TIMESTAMPTZ DEFAULT now(),
  updated_at       TIMESTAMPTZ DEFAULT now()
);

CREATE TABLE order_items (
  id         UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
  order_id   UUID REFERENCES orders(id) ON DELETE CASCADE,
  product_id UUID REFERENCES products(id),
  qty        INT NOT NULL,
  unit_price NUMERIC(10,2) NOT NULL,  -- snapshot at purchase time
  subtotal   NUMERIC(10,2) GENERATED ALWAYS AS (qty * unit_price) STORED
);
